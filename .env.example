# Public base URL the PWA calls (Caddy terminates TLS)
PUBLIC_API_URL=https://localhost

# Redis (internal compose network)
REDIS_URL=redis://redis:6379

# SQLite path on the worker's mounted /data volume
DB_PATH=/data/conveyor.db

# OrcaSlicer version baked into the worker image (pinned during the M1 spike)
ORCA_VERSION=2.1.1
