{
  "name": "conveyor",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "plugins/*/*"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:api": "bun run --cwd packages/api dev",
    "dev:worker": "bun run --cwd packages/worker dev",
    "dev": "docker compose up --build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "ioredis": "5.10.1"
  }
}
